# RasPike platform common settings.
# This file is loaded by bridge/web/network-auth/update systemd services.

RASPIKE_ROOT=/opt/raspike

# USB real device alias created by udev.
RASPIKE_REAL_DEVICE=/dev/raspike-real
RASPIKE_DEVICE_WAIT_RETRIES=20
RASPIKE_DEVICE_WAIT_SEC=1

# Bridge service settings. start.sh in raspike-bridge-ps5 reads these values.
RASPIKE_TELEMETRY_HOST=127.0.0.1
RASPIKE_TELEMETRY_PORT=8765
RASPIKE_WEB_CONTROL_HOST=0.0.0.0
RASPIKE_WEB_CONTROL_PORT=8766
RASPIKE_LEFT_PORT=B
RASPIKE_RIGHT_PORT=A
RASPIKE_ARM_PORT=C
RASPIKE_FORCE_PORT=D
RASPIKE_COLOR_PORT=E
RASPIKE_ULTRASONIC_PORT=F
RASPIKE_INIT_DELAY_SEC=0.2
RASPIKE_INIT_RETRIES=2
RASPIKE_INIT_ORDER=arm-first

# Web UI settings.
HOST=0.0.0.0
PORT=3000
RASPIKE_TARGET=local
RASPIKE_BRIDGE_HOST=127.0.0.1
BRIDGE_RETRY_SEC=1
# Optional: set this when Node.js is installed outside the system PATH.
# RASPIKE_NODE_BIN=/usr/bin/node

# Update settings.
BRIDGE_REF=main
WEB_RELEASE_REPO=Elic0de/raspike-web-control-v3
WEB_RELEASE_ASSET=dist.zip

# Optional: run update service after successful school Wi-Fi auth.
RASPIKE_RUN_UPDATE_AFTER_AUTH=false
