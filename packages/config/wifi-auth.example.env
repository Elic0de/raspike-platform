# Copy to /opt/raspike/config/wifi-auth.env and set permission to 600.
#   sudo chown raspike:raspike /opt/raspike/config/wifi-auth.env
#   sudo chmod 600 /opt/raspike/config/wifi-auth.env

# Dispatcher only starts auth when wlan0 is up and this SSID matches iwgetid -r.
SCHOOL_WIFI_SSID="YOUR_SCHOOL_WIFI_SSID"

# Captive portal auth endpoint.
SCHOOL_AUTH_URL="http://10.1.1.1/auth?redirect=http://connectivitycheck.gstatic.com/generate_204"

# Credentials. Do not commit real values.
# USERID/PASSWORD environment variables are also accepted as fallbacks.
SCHOOL_AUTH_USERNAME=""
SCHOOL_AUTH_PASSWORD=""

# Form field names for this captive portal.
SCHOOL_AUTH_USERNAME_FIELD="userid"
SCHOOL_AUTH_PASSWORD_FIELD="password"

# Optional extra POST fields in key=value&key2=value2 form.
SCHOOL_AUTH_EXTRA_FORM=""

# Online check used before and after auth.
SCHOOL_AUTH_CHECK_URL="http://connectivitycheck.gstatic.com/generate_204"
SCHOOL_AUTH_CHECK_PATTERN="204 No Content"
SCHOOL_AUTH_TIMEOUT_SEC=15
SCHOOL_AUTH_RETRY_WAIT_SEC=2
