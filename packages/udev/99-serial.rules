# raspike-platform managed file
#
# libraspike-art/spike/spike_env_setup_linux.sh は歴史的に次の rule を作ります。
#
#   SUBSYSTEM=="tty", ATTRS{idVendor}=="0483",ATTRS{idProduct}=="5740", SYMLINK+="USB_SPIKE",MODE="0666"
#
# raspike-platform では /dev/USB_SPIKE を bridge が作る PTY として使うため、
# 実機 SPIKE Hub を /dev/USB_SPIKE に割り当てません。
# 代わりに実機デバイスは /dev/raspike-real へ固定します。
#
# uninstall 時は install 前の /etc/udev/rules.d/99-serial.rules を
# /opt/raspike/backups/udev/99-serial.rules.original から復元します。

SUBSYSTEM=="tty", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5740", SYMLINK+="raspike-real", GROUP="dialout", MODE="0660"
